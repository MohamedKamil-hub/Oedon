#!/bin/bash
# Oedon CLI - The Invisible PaaS Control Plane
set -euo pipefail

# Path Configuration
PROJECT_DIR="${OEDON_PROJECT_DIR:-$(dirname "$(dirname "$(readlink -f "$0")")")}"
SCRIPTS="${PROJECT_DIR}/scripts"
APPS_LIST="${PROJECT_DIR}/apps.list"

# Load UI Colors
if [ -f "${SCRIPTS}/colors.sh" ]; then
    source "${SCRIPTS}/colors.sh"
    # Aseguramos que WHITE existe aunque no esté en el archivo de colores
    [ -z "${WHITE:-}" ] && WHITE='\033[1;37m'
else
    BOLD='' NC='' RED='' GREEN='' YELLOW='' BLUE='' CYAN='' WHITE=''
    OK='[OK]' ERR='[ERR]' INFO='[INFO]' SSL='[SSL]' WARN='[WARN]'
fi

# Source and export .env so child scripts inherit vars (Problem 3)
if [ -f "${PROJECT_DIR}/.env" ]; then
    set -a
    source "${PROJECT_DIR}/.env"
    set +a
fi

# Ensure log directory exists
mkdir -p /var/log/oedon/nginx 2>/dev/null || true

cd "$PROJECT_DIR"

cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$cmd" in
    janitor)
        echo -e "${INFO} Initializing system cleanup (Janitor Mode)..."
        bash "${SCRIPTS}/oedon-janitor.sh"
        ;;
    sync)
        echo -e "${INFO} Synchronizing infrastructure with application registry..."
        bash "${SCRIPTS}/sync_apps.sh" "$@"
        ;;
    add)
        if [ $# -lt 3 ]; then
            echo -e "${ERR} Missing parameters. Usage: oedon add <name> <port> <domain>"
            exit 1
        fi
        echo -e "${INFO} Registering: $1 -> $3.${DOMAIN}"
        echo "$1 | $2 | $3" >> "$APPS_LIST"
        bash "${SCRIPTS}/sync_apps.sh"
        echo -e "   ${OK} $3.${DOMAIN} registered and synced."
        ;;
    remove)
        if [ $# -lt 1 ]; then
            echo -e "${ERR} Missing parameter. Usage: oedon remove <name>"
            exit 1
        fi
        APP_NAME="$1"
        echo -e "${INFO} Removing application: ${APP_NAME}..."

        # Remove from apps.list
        if grep -q "^${APP_NAME} " "$APPS_LIST" 2>/dev/null; then
            sed -i "/^${APP_NAME} /d" "$APPS_LIST"
            echo -e "   ${OK} Removed from registry."
        else
            echo -e "   ${WARN} '${APP_NAME}' not found in apps.list."
        fi

        # Remove nginx config
        NGINX_CONF="${PROJECT_DIR}/config/nginx/sites-enabled/${APP_NAME}.conf"
        if [ -f "$NGINX_CONF" ]; then
            rm -f "$NGINX_CONF"
            echo -e "   ${OK} Nginx config removed."
        fi

        # Stop container if running
        if docker ps -q --filter "name=^${APP_NAME}$" | grep -q .; then
            APP_DIR="${PROJECT_DIR}/apps/${APP_NAME}"
            if [ -f "${APP_DIR}/docker-compose.yml" ] || [ -f "${APP_DIR}/docker-compose.yaml" ]; then
                docker compose -f "${APP_DIR}"/docker-compose.y* down 2>/dev/null || true
            else
                docker stop "${APP_NAME}" 2>/dev/null || true
            fi
            echo -e "   ${OK} Container stopped."
        fi

        # Reload nginx
        docker exec oedon-proxy nginx -s reload 2>/dev/null || true
        echo -e "   ${OK} Proxy reloaded."
        ;;
    list)
        echo -e "${BLUE}${BOLD}--- REGISTERED APPLICATIONS ---${NC}"
        if [ ! -s "$APPS_LIST" ]; then
            echo "Registry is empty."
        else
            grep -v '^#' "$APPS_LIST" | grep '|' || echo "No active entries found."
        fi
        ;;
    health)
        echo -e "${BLUE}${BOLD}--- CONTAINER HEALTH CHECK ---${NC}"
        while IFS= read -r line || [ -n "$line" ]; do
            [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
            name=$(echo "$line" | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $1); print $1}')
            port=$(echo "$line" | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $2); print $2}')
            [[ -z "$name" ]] && continue

            # Check container running
            if docker ps -q --filter "name=^${name}$" | grep -q .; then
                # HTTP health probe via docker network
                HTTP_CODE=$(docker exec oedon-proxy sh -c \
                    "wget -q -O /dev/null -S --timeout=5 http://${name}:${port}/ 2>&1 | head -1 | awk '{print \$2}'" 2>/dev/null || echo "ERR")
                if [[ "$HTTP_CODE" =~ ^[23] ]]; then
                    echo -e "   ${OK} ${name} :${port} -> HTTP ${HTTP_CODE}"
                else
                    echo -e "   ${WARN} ${name} :${port} -> HTTP ${HTTP_CODE:-timeout}"
                fi
            else
                echo -e "   ${ERR} ${name} -> container not running"
            fi
        done < "$APPS_LIST"
        ;;
    rotate)
        echo -e "${INFO} Entering Secret Rotation Wizard..."
        bash "${PROJECT_DIR}/scripts/generate-secrets.sh"
        ;;

    lockdown)
        echo -e "${RED}${BOLD}!!! CRITICAL SECURITY ALERT !!!${NC}"
        echo -e "${YELLOW}Enabling HMAC Port Knocking (Portero Digital).${NC}"
        echo ""
        read -p "Apply stealth mode and generate key? (y/N): " confirm
        if [[ $confirm == [yY] ]]; then
            echo -e "${INFO} Installing Portero Digital system service..."
            sudo ln -sf "${PROJECT_DIR}/internal/portero/oedon-portero.service" /etc/systemd/system/
            sudo systemctl daemon-reload
            sudo systemctl enable --now oedon-portero

            echo -e "${INFO} Hardening firewall rules..."
            sudo ufw allow "${PORTERO_UDP_PORT:-62201}"/udp
            sudo ufw deny "${SSH_PORT:-22}"/tcp
            sudo ufw reload

            # KEY GENERATION
            CLIENT_IP=$(hostname -I | awk '{print $1}')
            TARGET_FILE="${PROJECT_DIR}/knock_client.py"

            cat <<EOF > "$TARGET_FILE"
#!/usr/bin/env python3
import socket, hmac, hashlib, time

# Oedon Auto-generated Knock Client
SERVER_IP = "${CLIENT_IP}"
PORT = ${PORTERO_UDP_PORT:-62201}
SECRET = "${PORTERO_SECRET}"

def knock():
    ts = str(int(time.time()))
    mac = hmac.new(SECRET.encode(), ts.encode(), hashlib.sha256).hexdigest()
    payload = f"{ts}:{mac}".encode()
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(payload, (SERVER_IP, PORT))
    print(f"[OK] Knock sent to {SERVER_IP}:{PORT}")

if __name__ == "__main__":
    knock()
EOF
            chmod +x "$TARGET_FILE"

            echo -e "   ${OK} STEALTH MODE IS ACTIVE."
            echo -e "   ${OK} KEY GENERATED: ${TARGET_FILE}"
            echo -e "\n${CYAN}${BOLD}--- HOW TO USE YOUR KEY ---${NC}"
            echo -e "1. Download/Copy ${BOLD}knock_client.py${NC} to your PC."
            echo -e "2. Run this exact command on your local terminal:"
            echo -e "   ${GREEN}python knock_client.py${NC}"
            echo -e "${CYAN}----------------------------${NC}"
        else
            echo -e "${INFO} Lockdown sequence canceled."
        fi
        ;;
    secure)
        echo -e "${INFO} Running system hardening protocols..."
        bash "${SCRIPTS}/05-setup-firewall.sh"
        bash "${SCRIPTS}/06-setup-fail2ban.sh"
        bash "${SCRIPTS}/setup-motd.sh"
        echo -e "   ${OK} System security updated."
        ;;
    backup)
        echo -e "${INFO} Initializing system backup sequence..."
        bash "${SCRIPTS}/99-backup.sh"
        ;;
    watchdog-test)
        echo -e "${INFO} Running manual Guardian health check..."
        bash "${SCRIPTS}/oedon-watchdog.sh"
        ;;
    monitor)
        echo -e "${BLUE}${BOLD}--- GLOBAL OEDON MONITOR ---${NC}"
        echo -e "${CYAN}Streaming logs (Press Ctrl+C to exit)${NC}\n"
        sudo tail -f /var/log/oedon/nginx/*.log 2>/dev/null &
        docker ps --format "{{.Names}}" | xargs -I {} docker logs -f --tail 5 {} 2>/dev/null &
        trap 'kill $(jobs -p) 2>/dev/null' EXIT
        wait
        ;;
    certs)
        echo -e "${SSL} Managing SSL certificate lifecycle..."
        bash "${SCRIPTS}/generate_certs.sh"
        ;;
    deploy)
        bash "${SCRIPTS}/deploy.sh" "$@"
        ;;
    reset)
        echo -e "${RED}${BOLD}--- OEDON RESET ---${NC}"
        echo -e "${YELLOW}This will stop all containers, remove cron entries, and clean generated configs.${NC}"
        read -p "Proceed? (y/N): " confirm
        if [[ ! $confirm == [yY] ]]; then
            echo -e "${INFO} Reset canceled."
            exit 0
        fi

        echo -e "${INFO} Stopping all containers..."
        for app_dir in "${PROJECT_DIR}"/apps/*/; do
            [ -d "$app_dir" ] || continue
            if [ -f "${app_dir}docker-compose.yml" ] || [ -f "${app_dir}docker-compose.yaml" ]; then
                docker compose -f "${app_dir}"docker-compose.y* down 2>/dev/null || true
            fi
        done
        docker compose -f "${PROJECT_DIR}/docker-compose.yml" down 2>/dev/null || true

        echo -e "${INFO} Removing cron entries..."
        crontab -l 2>/dev/null | grep -v "oedon-watchdog.sh" | crontab - 2>/dev/null || true

        echo -e "${INFO} Cleaning generated nginx configs..."
        rm -f "${PROJECT_DIR}/config/nginx/sites-enabled/"*.conf 2>/dev/null || true

        echo -e "${INFO} Removing SSL certificates..."
        rm -f "${PROJECT_DIR}/config/nginx/ssl/oedon.crt" "${PROJECT_DIR}/config/nginx/ssl/oedon.key" 2>/dev/null || true

        read -p "Also delete .env? (y/N): " wipe_env
        if [[ $wipe_env == [yY] ]]; then
            rm -f "${PROJECT_DIR}/.env"
            echo -e "   ${OK} .env removed."
        fi

        echo -e "   ${OK} Reset complete. Run install.sh to start fresh."
        ;;
    up)      echo -e "${INFO} Starting infrastructure..."; docker compose up -d "$@" ;;
    down)    echo -e "${INFO} Stopping infrastructure..."; docker compose down "$@" ;;
    restart) echo -e "${INFO} Restarting services..."; docker restart "$@" || docker compose restart "$@" ;;
    status)  echo -e "${CYAN}${BOLD}--- CONTAINER STATUS ---${NC}"; docker compose ps ;;
    logs)    echo -e "${INFO} Attaching to container logs..."; docker compose logs -f "$@" ;;
    stats)   bash "${SCRIPTS}/oedon-stats.sh" ;;

    help|*)
        echo -e "${BLUE}${BOLD}OEDON CONTROL PLANE - Universal PaaS CLI${NC}"
        echo -e "Usage: sudo oedon <command> [arguments]\n"
        echo -e "${BOLD}CORE COMMANDS:${NC}"
        printf "  %-18s %s\n" "deploy" "Full system deployment"
        printf "  %-18s %s\n" "sync" "Sync registry with Nginx"
        printf "  %-18s %s\n" "add <n> <p> <sub>" "Register app (subdomain auto-resolved)"
        printf "  %-18s %s\n" "remove <name>" "Unregister and stop an app"
        printf "  %-18s %s\n" "list" "List registered apps"
        echo -e "\n${BOLD}OBSERVABILITY:${NC}"
        printf "  %-18s %s\n" "monitor" "Real-time log stream"
        printf "  %-18s %s\n" "health" "Per-container HTTP health check"
        printf "  %-18s %s\n" "up / down" "Service lifecycle control"
        printf "  %-18s %s\n" "restart" "Global container restart"
        printf "  %-18s %s\n" "status / logs" "Health and stdout monitoring"
        echo -e "\n${BOLD}SECURITY & MAINTENANCE:${NC}"
        printf "  %-18s %s\n" "lockdown" "Enable Stealth Mode (Port Knocking)"
        printf "  %-18s %s\n" "secure" "Apply security hardening"
        printf "  %-18s %s\n" "backup" "Run automated backup"
        printf "  %-18s %s\n" "watchdog-test" "Manual health inspection"
        printf "  %-18s %s\n" "certs" "SSL certificate management"
        printf "  %-18s %s\n" "stats" "Resource usage statistics"
        printf "  %-18s %s\n" "rotate" "Rotate infrastructure secrets"
        printf "  %-18s %s\n" "janitor" "Cleanup logs, docker orphans and temp files"    
        printf "  %-18s %s\n" "reset" "Tear down everything and clean state"
        echo ""
        ;;
esac
