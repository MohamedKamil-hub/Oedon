# ====================== ENTORNO Y SECRETOS ======================
.env
*.env.local
internal/portero/knock_client.py
knock_client.py

# ====================== DATOS PERSISTENTES ======================
data/
logs/
**/node_modules/

# ====================== CERTIFICADOS Y CLAVES ======================
config/nginx/ssl/*.key
config/nginx/ssl/*.crt
*.pem
config/ssh/id_oedon_server

# ====================== WORDPRESS - SOLO LO ESENCIAL ======================
# Ignoramos TODO wp-content excepto tus archivos personalizados
apps/wordpress/wp-content/*
!apps/wordpress/wp-content/index.php
!apps/wordpress/wp-content/mu-plugins/
!apps/wordpress/wp-content/mu-plugins/*.php
!apps/wordpress/wp-content/plugins/index.php
!apps/wordpress/wp-content/themes/index.php

# Ignoramos temas por defecto que trae la imagen oficial
apps/wordpress/wp-content/themes/twentytwenty*/
apps/wordpress/wp-content/plugins/akismet/
apps/wordpress/wp-content/plugins/hello.php

# Archivos generados por WordPress en runtime (nunca commitear)
apps/wordpress/wp-content/uploads/
apps/wordpress/wp-content/upgrade/
apps/wordpress/wp-content/languages/
apps/wordpress/wp-content/cache/
apps/wordpress/wp-content/backup-db/
apps/wordpress/wp-content/backups/

# ====================== CONFIGURACIÓN GENERADA ======================
config/nginx/sites-enabled/
config/nginx/ssl/

# ====================== EDITOR Y SISTEMA ======================
.DS_Store
.vscode/
__pycache__/
*.swp
*.swo
.idea/

# ====================== OTROS ======================
digest.txt
