# ══════════════════════════════════════════════════════════
# OEDON -- Configuration (.env)
# Copy to .env and change ALL values marked CHANGE_ME
# ══════════════════════════════════════════════════════════

# -- Domain ──────────────────────────────────────────────
# Used by: nginx vhosts, SSL generation, stats display
DOMAIN=CHANGE_ME

# Modes: local | production
# local = mkcert SSL, production = Let's Encrypt
APP_ENV=local

# -- Docker ──────────────────────────────────────────────
NETWORK_NAME=oedon-network

# -- Ports ───────────────────────────────────────────────
SSH_PORT=22
HTTP_PORT=80
HTTPS_PORT=443
PORTERO_UDP_PORT=62201

# -- Portero Digital (HMAC port knocking) ────────────────
# Auto-generated by generate-secrets.sh
PORTERO_SECRET=CHANGE_ME
PORTERO_WINDOW=60
PORTERO_TOLERANCE=30

# -- WordPress / MariaDB ────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=CHANGE_ME

# -- SSL (paths relative to config/nginx/ssl/) ──────────
SSL_CERT=oedon.crt
SSL_KEY=oedon.key

# -- Python App ──────────────────────────────────────────
# Public key for API signature verification (leave empty if unused)
OEDON_PUBLIC_KEY=

# -- Telegram (watchdog + backups) ───────────────────────
# Optional: leave empty to disable notifications
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# -- Watchdog ────────────────────────────────────────────
WATCHDOG_DISK_THRESHOLD=85
WATCHDOG_MEM_THRESHOLD=90
WATCHDOG_CONTAINERS="oedon-proxy oedon-static wordpress-db wordpress python-app"
WATCHDOG_COOLDOWN_DIR=/tmp/oedon-watchdog
WATCHDOG_COOLDOWN_MIN=30

# -- Certbot (production only) ──────────────────────────
CERTBOT_EMAIL=CHANGE_ME
